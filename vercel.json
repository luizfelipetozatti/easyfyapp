{
  "buildCommand": "turbo build --filter=@easyfyapp/web",
  "outputDirectory": ".next",
  "installCommand": "pnpm install --frozen-lockfile",
  "functions": {
    "app/api/**/*.ts": {
      "maxDuration": 10
    }
  },
  "crons": [
    {
      "path": "/api/cron/reminders",
      "schedule": "0 * * * *"
    }
  ],
  "env": {
    "SKIP_ENV_VALIDATION": "true"
  }
}