# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase Service Role (server-side only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Prisma
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Evolution API (WhatsApp)
EVOLUTION_API_URL=https://your-evolution-api.com
EVOLUTION_API_KEY=your-evolution-api-key
EVOLUTION_INSTANCE=easyfy

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Asaas (gateway de pagamento)
# Obtenha sua API key em: https://app.asaas.com/config/integracoes
ASAAS_API_KEY=$aact_xxxxxxxxxxxxxxxxxxxx
# Token de autenticação dos webhooks (definido no painel do Asaas)
ASAAS_WEBHOOK_TOKEN=seu_token_secreto_aqui
# Use "true" para ambiente de testes (sandbox)
ASAAS_SANDBOX=true
